      "end_utc": "2026-06-01T00:00:00Z",
      "expected_bars": 1488,
      "minimum_rows": 1200
    }
  ],
  "model_train_test_split": {
    "strategy": "chronological_holdout",
    "train_fraction": 0.8,
    "test_fraction": 0.2,
    "minimum_test_samples": 10,
    "minimum_train_samples": 300
  },
  "training_defaults": {
    "horizon_bars": 2,
    "buy_threshold": 0.005,
    "sell_threshold": 0.005,
    "min_train_samples": 300,
    "cost_bps": 9.0,
    "optimize_thresholds": true,
    "labeling_mode": "triple_barrier_v2",
    "trade_quality_min_score": 0.55,
    "action_confidence_threshold": 0.6
  },
  "evaluation_priority_metrics": [
    "execution_backtest_realized_pnl_delta_usd",
