{
  "contract": "trigger_ranked_ablation_plan.v1",
  "name": "next_cycle_ranked_feature_ablation_30m",
  "description": "Concrete ranked-feature specification and trigger-model ablation matrix for the next training cycle.",
  "scope": {
    "exchange": "binanceus",
    "symbol": "BTC/USDT",
    "timeframe": "30m"
  },
  "feature_spec": {
    "proxy_engine_version": "ranked_features.v1",
    "feature_columns": [
      "flow_taker_buy_share_6",
      "flow_taker_buy_share_24",
      "flow_signed_volume_imbalance_24",
      "flow_vwap_dislocation_12",
      "derivatives_open_interest_delta_24",
      "derivatives_funding_rate_z_24",
      "derivatives_basis_z_24",
      "derivatives_long_short_ratio_z_24",
      "onchain_exchange_netflow_z_24",
      "onchain_stablecoin_inflow_ratio_24",
      "onchain_exchange_reserve_delta_24",
      "options_put_call_oi_ratio_z_24",
      "options_iv_term_slope_7_30",
      "options_skew_25d_z_24",
      "regime_trend_strength_24",
      "regime_volatility_ratio_24_96",
      "regime_momentum_vol_adj_24"
    ],
    "stable_default_feature_columns": [
      "flow_signed_volume_imbalance_24",
      "derivatives_open_interest_delta_24",
      "derivatives_basis_z_24",
      "onchain_exchange_netflow_z_24",
      "options_put_call_oi_ratio_z_24",
      "regime_trend_strength_24",
      "regime_momentum_vol_adj_24"
    ],
    "shared_feature_construction_rules": {
      "external_alignment": "backward merge_asof on timestamp with exact matches allowed",
      "external_missing_fallback": "proxy feature fallback",
      "numeric_fill_default": 0.0,
      "numeric_clip_range": [
        -8.0,
        8.0
      ],
      "rolling_zscore_window_bars": 24,
      "rolling_zscore_min_periods_rule": "max(4, window/3)"
    },
    "field_windows": {
      "flow_taker_buy_share_6": {
        "family": "flow",
        "aggregation_windows_bars": [
          6
        ],
        "definition": "rolling_sum(up_volume,6) / (rolling_sum(up_volume,6)+rolling_sum(down_volume,6))"
      },
      "flow_taker_buy_share_24": {
        "family": "flow",
        "aggregation_windows_bars": [
          24
        ],
        "definition": "rolling_sum(up_volume,24) / (rolling_sum(up_volume,24)+rolling_sum(down_volume,24))"
      },
      "flow_signed_volume_imbalance_24": {
        "family": "flow",
        "aggregation_windows_bars": [
          24
        ],
        "definition": "(rolling_sum(up_volume,24)-rolling_sum(down_volume,24)) / (rolling_sum(up_volume,24)+rolling_sum(down_volume,24))"
      },
      "flow_vwap_dislocation_12": {
        "family": "flow",
        "aggregation_windows_bars": [
          12
        ],
        "definition": "(close / rolling_vwap(close*volume,12)) - 1.0"
      },
      "derivatives_open_interest_delta_24": {
        "family": "derivatives",
        "aggregation_windows_bars": [
          24,
          96
        ],
        "definition": "(rolling_mean(volume,24) / rolling_mean(volume,96)) - 1.0"
      },
      "derivatives_funding_rate_z_24": {
        "family": "derivatives",
        "aggregation_windows_bars": [
          1,
          4,
          12,
          24
        ],
        "definition": "zscore24(ewm_span12(ret_4-ret_1))"
      },
      "derivatives_basis_z_24": {
        "family": "derivatives",
        "aggregation_windows_bars": [
          24
        ],
        "definition": "zscore24((close / rolling_mean(close,24)) - 1.0)"
      },
      "derivatives_long_short_ratio_z_24": {
        "family": "derivatives",
        "aggregation_windows_bars": [
          12,
          24
        ],
        "definition": "zscore24(ewm_span12(flow_signed_volume_imbalance_24))"
      },
      "onchain_exchange_netflow_z_24": {
        "family": "onchain",
        "aggregation_windows_bars": [
          24
        ],
        "definition": "zscore24((rolling_sum(down_volume,24)-rolling_sum(up_volume,24)) / rolling_sum(volume,24))"
      },
      "onchain_stablecoin_inflow_ratio_24": {
        "family": "onchain",
        "aggregation_windows_bars": [
          24
        ],
        "definition": "log((rolling_sum(up_volume,24)+1)/(rolling_sum(down_volume,24)+1))"
      },
      "onchain_exchange_reserve_delta_24": {
        "family": "onchain",
        "aggregation_windows_bars": [
          24
        ],
        "definition": "-ret_24 * (1 + abs(zscore24(volume)))"
      },
      "options_put_call_oi_ratio_z_24": {
        "family": "options",
        "aggregation_windows_bars": [
          24
        ],
        "definition": "zscore24(log((rolling_mean(downside_move,24)+1e-6)/(rolling_mean(upside_move,24)+1e-6)))"
      },
      "options_iv_term_slope_7_30": {
        "family": "options",
        "aggregation_windows_bars": [
          7,
          30
        ],
        "definition": "rolling_std(ret_1,7) - rolling_std(ret_1,30)"
      },
      "options_skew_25d_z_24": {
        "family": "options",
        "aggregation_windows_bars": [
          24
        ],
        "definition": "zscore24(abs(rolling_q25(ret_1,24)) - abs(rolling_q75(ret_1,24)))"
      },
      "regime_trend_strength_24": {
        "family": "regime",
        "aggregation_windows_bars": [
          24,
          96
        ],
        "definition": "(rolling_mean(close,24) / rolling_mean(close,96)) - 1.0"
      },
      "regime_volatility_ratio_24_96": {
        "family": "regime",
        "aggregation_windows_bars": [
          24,
          96
        ],
        "definition": "(rolling_std(ret_1,24) / rolling_std(ret_1,96)) - 1.0"
      },
      "regime_momentum_vol_adj_24": {
        "family": "regime",
        "aggregation_windows_bars": [
          24
        ],
        "definition": "ret_24 / (rolling_std(ret_1,24)+1e-6)"
      }
    }
  },
  "validation_splits": [
    {
      "name": "uptrend_2025_04",
      "regime": "uptrend",
      "start_utc": "2025-04-01T00:00:00Z",
