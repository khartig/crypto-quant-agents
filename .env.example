# Primary external storage mount for quant datasets and outputs.
QUANT_DATA_ROOT=/mnt/quant-data
ALLOW_UNMOUNTED_DATA_ROOT=0

# Default pipeline market settings.
EXCHANGE_ID=kraken
SYMBOL=BTC/USDT
TIMEFRAME=1h

# Secrets and execution guards.
# Set REQUIRE_EXCHANGE_SECRETS=1 to force secret checks in `run-daily` and `doctor`.
REQUIRE_EXCHANGE_SECRETS=0
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_API_PASSPHRASE=

# Milestone 4 agent-plane defaults (Ollama + deterministic risk gate).
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_STRATEGY_MODEL=llama3.1:8b
OLLAMA_OPS_MODEL=llama3.1:8b
AGENT_STEP_RETRIES=2
AGENT_MINIMUM_BARS=120
RISK_MIN_TOTAL_RETURN=0.0
RISK_MIN_SHARPE=0.0
RISK_MAX_DRAWDOWN=-0.20
RISK_MIN_SIGNAL_CONFIDENCE=0.55
PAPER_TRADE_NOTIONAL_USD=100.0

