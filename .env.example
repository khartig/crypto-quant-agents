# Primary external storage mount for quant datasets and outputs.
QUANT_DATA_ROOT=/mnt/quant-data
ALLOW_UNMOUNTED_DATA_ROOT=0

# Default pipeline market settings.
EXCHANGE_ID=kraken
SYMBOL=BTC/USDT
TIMEFRAME=1h

# Secrets and execution guards.
# Set REQUIRE_EXCHANGE_SECRETS=1 to force secret checks in `run-daily` and `doctor`.
REQUIRE_EXCHANGE_SECRETS=0
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_API_PASSPHRASE=

# Milestone 4 agent-plane defaults (Ollama + deterministic risk gate).
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=600
OLLAMA_STRATEGY_MODEL=llama3.1:8b
OLLAMA_OPS_MODEL=llama3.1:8b
AGENT_STEP_RETRIES=2
AGENT_MINIMUM_BARS=120
REGIME_DETECTOR_MODE=score
REGIME_POLICY_MODE=legacy
REGIME_POLICY_MIN_ACTIONABLE_CONFIDENCE=0.50
REGIME_POLICY_TRANSITION_CONFIDENCE=0.65
REGIME_TOUCHPOINT_PROMPTING_ENABLED=1
REGIME_TOUCHPOINT_CALIBRATION_ENABLED=1
REGIME_TOUCHPOINT_SELF_CRITIQUE_ENABLED=1
REGIME_TOUCHPOINT_RISK_GATE_ENABLED=1
REGIME_VOLATILITY_THRESHOLD=0.03
REGIME_TREND_SPREAD_THRESHOLD=0.01
REGIME_PERSISTENCE_BARS=3
REGIME_ENABLED=1
REGIME_ABLATION_MODE=0
PRIORITY2_FEATURES_ENABLED=1
PRIORITY2_EXTERNAL_FEATURES_PATH=
PRIORITY2_RETRIEVAL_PROVIDER=okx_public
PRIORITY2_RETRIEVAL_TIMEOUT_SECONDS=20
PRIORITY2_RETRIEVAL_MAX_POINTS=500
PRIORITY2_RETRIEVAL_BASE_URL=https://www.okx.com
PRIORITY2_LOCAL_FEATURE_OVERRIDES_PATH=
RISK_MIN_TOTAL_RETURN=0.0
RISK_MIN_SHARPE=0.0
RISK_MAX_DRAWDOWN=-0.20
RISK_MAX_COST_RETURN_DRAG=0.05
RISK_MAX_COST_PRESSURE_SCORE=0.95
RISK_MIN_SIGNAL_CONFIDENCE=0.55
RISK_MIN_WALKFORWARD_QUALITY_SCORE=0.43
RISK_MIN_REGIME_CONFIDENCE=0.45
BACKTEST_FEE_BPS=5.0
BACKTEST_SLIPPAGE_BPS=2.5
WALK_FORWARD_FEE_BPS=5.0
WALK_FORWARD_SLIPPAGE_BPS=2.5
WALK_FORWARD_TRAIN_BARS=240
WALK_FORWARD_VALIDATE_BARS=72
WALK_FORWARD_STEP_BARS=72
WALK_FORWARD_MIN_WINDOWS=3
CALIBRATION_MIN_WALKFORWARD_SHARPE=0.10
CALIBRATION_CONFIDENCE_FLOOR=0.05
CALIBRATION_CONFIDENCE_CEILING=0.95
CALIBRATION_MAX_CONTRADICTIONS=0
CALIBRATION_DIRECTIONAL_EDGE_THRESHOLD=0.0
CALIBRATION_QUALITY_PENALTY_STRENGTH=0.25
CALIBRATION_DIRECTIONAL_CONTRADICTION_PENALTY=0.35
CALIBRATION_COST_PRESSURE_PENALTY_STRENGTH=0.30
SELF_CRITIQUE_MIN_SCORE=0.55
SELF_CRITIQUE_MAX_FINDINGS=6
OPS_REPORT_VERBOSITY=standard
AGENT_ENSEMBLE_MODE=adaptive
AGENT_ENSEMBLE_ARMS=sma_baseline,technical_composite,llm_context
AGENT_ENSEMBLE_DECAY_HORIZON=96
AGENT_ENSEMBLE_EXPLORATION_WEIGHT=0.08
AGENT_ENSEMBLE_TURNOVER_PENALTY_BPS=8.0
PAPER_TRADE_NOTIONAL_USD=100.0
PAPER_TRADE_STARTING_CASH_USD=10000.0
PAPER_TRADE_FEE_BPS=5.0
PAPER_TRADE_SLIPPAGE_BPS=1.0

# Paper account connectivity checks.
# provider=tradingview => reachability + limitation diagnostics only (no direct paper-account API).
# provider=ccxt => attempts authenticated connectivity against exchange paper/testnet endpoints.
PAPER_ACCOUNT_PROVIDER=tradingview
PAPER_ACCOUNT_EXCHANGE=kraken
PAPER_ACCOUNT_SANDBOX=1
PAPER_ACCOUNT_TIMEOUT_SECONDS=15
PAPER_ACCOUNT_API_KEY=
PAPER_ACCOUNT_API_SECRET=
PAPER_ACCOUNT_API_PASSPHRASE=
TRADINGVIEW_BASE_URL=https://www.tradingview.com
# Trigger model training + prediction defaults.
TRIGGER_MODEL_HORIZON_BARS=6
TRIGGER_MODEL_BUY_THRESHOLD=0.012
TRIGGER_MODEL_SELL_THRESHOLD=0.003
TRIGGER_MODEL_MIN_TRAIN_SAMPLES=120
TRIGGER_MODEL_COST_BPS=7.5
TRIGGER_MODEL_OPTIMIZE_THRESHOLDS=1
TRIGGER_MODEL_LABELING_MODE=triple_barrier_v2
TRIGGER_MODEL_TRADE_QUALITY_MIN_SCORE=0.55
TRIGGER_MODEL_ACTION_CONFIDENCE_THRESHOLD=0.55

# Continuous trigger monitoring + notification defaults.
TRIGGER_MONITOR_POLL_SECONDS=300
TRIGGER_MONITOR_SIGNAL_CONFIDENCE=0.60
TRIGGER_MONITOR_WEBHOOK_URL=
TRIGGER_MONITOR_NOTIFY_ON_HOLD=0

